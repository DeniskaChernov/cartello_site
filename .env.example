# --- Фронт (Vite) — скопируйте в .env.local для разработки ---
# Полный URL эндпоинта заявок (удобно для Railway API):
# VITE_LEAD_API_URL=https://your-api.up.railway.app/make-server-cc5df832/send-telegram
#
# Или база + путь (без слэша в конце base):
# VITE_API_BASE_URL=https://your-api.up.railway.app
# VITE_LEAD_API_PATH=/make-server-cc5df832/send-telegram
#
# Токен для Authorization (если бэкенд не Supabase): VITE_API_AUTH_TOKEN=...
# Иначе для Supabase Edge:
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Бэкенд (Deno на Railway или Supabase Edge) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALLOWED_ORIGINS=https://your-frontend.up.railway.app
# PORT=8080
# GOOGLE_SHEETS_CREDENTIALS=
# GOOGLE_SHEETS_ID=
