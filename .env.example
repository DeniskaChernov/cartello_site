# --- SEO / домен (для canonical, JSON-LD, проверки Google Search Console) ---
# VITE_SITE_URL=https://cartello.uz
# VITE_GOOGLE_SITE_VERIFICATION=код_из_meta_тега_GSC
# Опционально: превью для соцсетей (положите og.jpg в public/ и укажите полный URL)
# VITE_OG_IMAGE_URL=https://cartello.uz/og.jpg
# После смены домена обновите public/robots.txt и public/sitemap.xml (URL в Sitemap).

# --- Фронт (Vite) ---
# Для продакшн-сборки на Railway задайте VITE_* в переменных окружения до шага build.
# Локально можно не задавать: `npm run dev` проксирует /api → http://127.0.0.1:8787 (запустите API: deno run --allow-net --allow-env server/index.tsx).
#
# Полный URL эндпоинта заявок:
# VITE_LEAD_API_URL=http://localhost:8787/api/send-telegram
#
# Или база + путь (без слэша в конце base):
# VITE_API_BASE_URL=http://localhost:8787
# VITE_LEAD_API_PATH=/api/send-telegram
#
# Если на API включена проверка ключа:
# VITE_API_AUTH_TOKEN=

# --- Бэкенд (Deno, Railway) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALLOWED_ORIGINS=http://localhost:5173
# PORT=8080
# GOOGLE_SHEETS_CREDENTIALS=
# GOOGLE_SHEETS_ID=
#
# PostgreSQL (Railway: добавьте плагин Postgres — переменная DATABASE_URL подставится в сервис API)
# DATABASE_URL=postgresql://user:pass@host:port/railway
